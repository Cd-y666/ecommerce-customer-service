# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# -----------------------------------------------------------------------------
# 虚拟环境
# -----------------------------------------------------------------------------
venv/
ENV/
env/
.venv

# -----------------------------------------------------------------------------
# IDE 相关
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# 环境变量文件（包含敏感信息，不能上传）
# -----------------------------------------------------------------------------
.env
*.env

# -----------------------------------------------------------------------------
# 知识库数据（本地生成，不需要上传）
# -----------------------------------------------------------------------------
chroma_db/
ecommerce_chroma_db/
*.chroma

# -----------------------------------------------------------------------------
# 临时文件
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.log
*.cache

# -----------------------------------------------------------------------------
