# =============================================================================
# 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# =============================================================================

# -----------------------------------------------------------------------------
# 通用配置（两个项目都需要）
# -----------------------------------------------------------------------------

# Ollama 服务地址（本地部署默认即可）
OLLAMA_BASE_URL=http://127.0.0.1:11434

# LLM 模型名称（需提前用 ollama pull 下载）
LLM_MODEL=deepseek-r1:7b

# Embedding 模型名称（需提前用 ollama pull 下载）
EMBED_MODEL=shaw/dmeta-embedding-zh


# -----------------------------------------------------------------------------
# ecommerce_rag_bot.py 专用配置
# -----------------------------------------------------------------------------

# ChromaDB 持久化目录（电商知识库存储位置）
ECOM_CHROMA_DIR=./ecommerce_chroma_db

# 客服联系方式（在回答中展示给用户）
SUPPORT_HOTLINE=400-888-XXXX
SUPPORT_EMAIL=service@example.com
SUPPORT_HOURS=工作日 9:00-18:00


# -----------------------------------------------------------------------------
# 安全配置（可选，有默认值）
# -----------------------------------------------------------------------------

# 单文件最大上传大小（MB）
MAX_FILE_SIZE_MB=20

# 单次最多上传文件数量
MAX_FILES=10

# 用户输入最大长度（字符数）
MAX_INPUT_LEN=500

# 模型输出最大长度（字符数）
MAX_OUTPUT_LEN=3000

# Agent 最大迭代次数（防止死循环）
MAX_ITERATIONS=4

# 检索结果数量（Top-K）
RETRIEVAL_TOP_K=5

# 单会话最大消息数（速率限制）
MAX_MSG_PER_SESSION=100

# 部署模式：dev=开发模式（显示配置），production=生产模式（隐藏配置）
DEPLOY_MODE=dev
